{
  "name": "nyusu",
  "version": "1.0.0",
  "description": "Gaming Team Platform",
  "main": "electron.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "electron": "electron .",
    "build-win": "electron-builder --win portable",
    "build-installer": "electron-builder --win nsis"
  },
  "build": {
    "appId": "com.nyusu.app",
    "productName": "NYUSU",
    "directories": {
      "output": "dist-electron"
    },
    "files": [
      "**/*",
      "!dist/**",
      "!dist-electron/**",
      "!*.md"
    ],
    "win": {
      "target": [
        "portable",
        "nsis"
      ],
      "icon": "public/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": "public/icon.ico"
    },
    "portable": {
      "artifactName": "NYUSU-Portable.exe"
    }
  },
  "keywords": [],
  "author": "Jonas",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "connect-mongo": "^6.0.0",
    "dotenv": "^17.3.1",
    "ejs": "^4.0.1",
    "express": "^5.2.1",
    "express-rate-limit": "^8.3.1",
    "express-session": "^1.19.0",
    "helmet": "^8.1.0",
    "mongoose": "^9.2.3"
  },
  "devDependencies": {
    "electron": "^40.8.0",
    "electron-builder": "^26.8.1",
    "nodemon": "^3.1.14"
  }
}
