<!DOCTYPE html>
<html lang="de">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Registrieren | Team Manager</title>
    <link rel="stylesheet" href="/css/style.css">
</head>
<body class="auth-page">
<div class="auth-container">
    <div class="auth-card">
        <div class="auth-logo">
            <span style="font-size:2.5rem">⚔️</span>
            <h1>Team Manager</h1>
            <p class="auth-subtitle">Erstelle deinen Account</p>
        </div>

        <% if (error) { %>
            <div class="alert alert-error"><%= error %></div>
        <% } %>
        <% if (success) { %>
            <div class="alert alert-success"><%= success %></div>
        <% } %>

        <form action="/auth/register" method="POST" class="auth-form">
            <div class="form-group">
                <label for="username">Benutzername</label>
                <input type="text" id="username" name="username" placeholder="CoolGamer99" required>
            </div>
            <div class="form-group">
                <label for="email">E-Mail</label>
                <input type="email" id="email" name="email" placeholder="deine@email.de" required>
            </div>
            <div class="form-group">
                <label for="password">Passwort</label>
                <input type="password" id="password" name="password" placeholder="••••••••" required minlength="6">
            </div>
            <div class="form-group">
                <label for="confirmPassword">Passwort bestätigen</label>
                <input type="password" id="confirmPassword" name="confirmPassword" placeholder="••••••••" required>
            </div>
            <button type="submit" class="btn btn-primary btn-full">Account erstellen</button>
        </form>

        <p class="auth-switch">Schon registriert? <a href="/auth/login">Anmelden</a></p>
    </div>
</div>
</body>
</html>

