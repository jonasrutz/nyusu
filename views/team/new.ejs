<!DOCTYPE html>
<html lang="de">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Team erstellen | nyusu</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Poppins:wght@600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
    <link rel="stylesheet" href="/css/style.css">
    <% if (user && user.accentColor) { %>
    <style>
        :root {
            --accent: <%= user.accentColor %>;
            --accent-hover: <%= user.accentColor %>cc;
            --accent-glow: <%= user.accentColor %>4d;
        }
        .user-avatar {
            background: linear-gradient(135deg, <%= user.accentColor %> 0%, <%= user.accentColor %>99 100%) !important;
            box-shadow: 0 4px 20px <%= user.accentColor %>66 !important;
        }
    </style>
    <% } %>
</head>
<body>
<%- include('../layout/sidebar') %>
<div class="main-content">
    <div class="page-header">
        <h2><i class="fas fa-plus-circle"></i> Neues Team erstellen</h2>
        <a href="/teams" class="btn btn-ghost"><i class="fas fa-arrow-left"></i> Zurück</a>
    </div>

    <% if (error) { %>
        <div class="alert alert-error"><%= error %></div>
    <% } %>

    <div class="form-card">
        <form action="/teams" method="POST" class="form-standard">
            <input type="hidden" name="_csrf" value="<%= csrfToken %>">
            <div class="form-group">
                <label for="name">Teamname *</label>
                <input type="text" id="name" name="name" placeholder="z.B. Alpha Wolves" required>
            </div>
            <div class="form-group">
                <label for="game">Spiel</label>
                <input type="text" id="game" name="game" placeholder="z.B. Valorant, CS2…">
            </div>
            <div class="form-group">
                <label for="description">Beschreibung</label>
                <textarea id="description" name="description" rows="4" placeholder="Beschreibe dein Team…"></textarea>
            </div>
            <button type="submit" class="btn btn-primary">Team erstellen</button>
        </form>
    </div>
</div>
<script>
// Mobile Sidebar Toggle
(function() {
    const toggle = document.getElementById('mobileMenuToggle');
    const sidebar = document.getElementById('sidebar');
    const overlay = document.getElementById('sidebarOverlay');
    
    if (toggle && sidebar && overlay) {
        toggle.addEventListener('click', () => {
            sidebar.classList.toggle('open');
            overlay.classList.toggle('active');
            toggle.innerHTML = sidebar.classList.contains('open') 
                ? '<i class="fas fa-times"></i>' 
                : '<i class="fas fa-bars"></i>';
        });
        
        overlay.addEventListener('click', () => {
            sidebar.classList.remove('open');
            overlay.classList.remove('active');
            toggle.innerHTML = '<i class="fas fa-bars"></i>';
        });
    }
})();
</script>
</body>
</html>

