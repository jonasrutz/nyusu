<!DOCTYPE html>
<html lang="de">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= team.name %> | Team Manager</title>
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
<%- include('../layout/sidebar') %>
<div class="main-content team-detail-layout">

    <!-- ── Centre Panel ─────────────────────────────────── -->
    <div class="team-centre">

        <!-- Header -->
        <div class="page-header">
            <div>
                <h2><%= team.name %></h2>
                <% if (team.game) { %><span class="team-game">🎮 <%= team.game %></span><% } %>
            </div>
            <div class="header-actions">
                <% if (!isMember) { %>
                    <form action="/teams/<%= team._id %>/join" method="POST" style="display:inline">
                        <button class="btn btn-primary">Team beitreten ✓</button>
                    </form>
                <% } else if (team.founder._id.toString() !== user.userId) { %>
                    <form action="/teams/<%= team._id %>/leave" method="POST" style="display:inline"
                          onsubmit="return confirm('Team wirklich verlassen?')">
                        <button class="btn btn-danger">Team verlassen</button>
                    </form>
                <% } %>
                <% if (isAdmin) { %>
                    <a href="/teams/<%= team._id %>/edit" class="btn btn-secondary">✏️ Bearbeiten</a>
                <% } %>
                <% if (team.founder._id.toString() === user.userId) { %>
                    <form action="/teams/<%= team._id %>/delete" method="POST" style="display:inline"
                          onsubmit="return confirm('Team wirklich auflösen? Diese Aktion kann nicht rückgängig gemacht werden!')">
                        <button class="btn btn-danger">🗑️ Auflösen</button>
                    </form>
                <% } %>
                <a href="/teams" class="btn btn-ghost">← Zurück</a>
            </div>
        </div>

        <!-- Tabs -->
        <div class="tabs">
            <button class="tab-btn <%= tab === 'chat' ? 'active' : '' %>" onclick="switchTab('chat')">💬 Chat</button>
            <button class="tab-btn <%= tab === 'docs' ? 'active' : '' %>" onclick="switchTab('docs')">📄 Dokumente</button>
        </div>

        <!-- ── Chat Tab ─────────────────────────────────── -->
        <div id="tab-chat" class="tab-content <%= tab === 'chat' ? 'active' : '' %>">
            <div class="chat-feed" id="chatFeed">
                <% if (messages.length === 0) { %>
                    <div class="empty-state small"><p>Noch keine Nachrichten. Seid die Ersten!</p></div>
                <% } %>
                <% messages.forEach(msg => { %>
                <div class="chat-message <%= msg.author._id.toString() === user.userId ? 'own' : '' %>">
                    <div class="msg-avatar"><%= msg.author.username.charAt(0).toUpperCase() %></div>
                    <div class="msg-body">
                        <div class="msg-meta">
                            <span class="msg-author"><%= msg.author.username %></span>
                            <span class="msg-time"><%= new Date(msg.createdAt).toLocaleString('de-CH') %></span>
                        </div>
                        <p class="msg-content"><%= msg.content %></p>
                    </div>
                    <% if (msg.author._id.toString() === user.userId) { %>
                    <form action="/teams/<%= team._id %>/chat/<%= msg._id %>/delete" method="POST" class="msg-delete">
                        <button class="btn-icon" title="Löschen" onclick="return confirm('Nachricht löschen?')">🗑️</button>
                    </form>
                    <% } %>
                </div>
                <% }) %>
            </div>

            <% if (isMember) { %>
            <form action="/teams/<%= team._id %>/chat" method="POST" class="chat-form">
                <input type="text" name="content" placeholder="Nachricht eingeben…" class="chat-input" autocomplete="off" required>
                <button type="submit" class="btn btn-primary">Senden</button>
            </form>
            <% } else { %>
            <p class="join-hint">Tritt dem Team bei, um am Chat teilzunehmen.</p>
            <% } %>
        </div>

        <!-- ── Documents Tab ───────────────────────────── -->
        <div id="tab-docs" class="tab-content <%= tab === 'docs' ? 'active' : '' %>">
            <% if (isMember) { %>
            <div class="doc-add-form">
                <h4>📎 Ressource hinzufügen</h4>
                <form action="/teams/<%= team._id %>/documents" method="POST" class="form-inline">
                    <input type="text"  name="title"       placeholder="Titel *"         required>
                    <input type="url"   name="url"         placeholder="URL (https://…) *" required>
                    <input type="text"  name="description" placeholder="Beschreibung">
                    <button type="submit" class="btn btn-primary">Hinzufügen</button>
                </form>
            </div>
            <% } %>

            <% if (documents.length === 0) { %>
                <div class="empty-state small"><p>Noch keine Dokumente vorhanden.</p></div>
            <% } else { %>
            <table class="doc-table">
                <thead>
                    <tr><th>Titel</th><th>Beschreibung</th><th>Erstellt von</th><th>Datum</th><th></th></tr>
                </thead>
                <tbody>
                <% documents.forEach(doc => { %>
                <tr>
                    <td><a href="<%= doc.url %>" target="_blank" rel="noopener" class="doc-link">🔗 <%= doc.title %></a></td>
                    <td><%= doc.description || '—' %></td>
                    <td><%= doc.uploadedBy.username %></td>
                    <td><%= new Date(doc.createdAt).toLocaleDateString('de-CH') %></td>
                    <td>
                        <% if (doc.uploadedBy._id.toString() === user.userId) { %>
                        <form action="/teams/<%= team._id %>/documents/<%= doc._id %>/delete" method="POST"
                              onsubmit="return confirm('Dokument löschen?')">
                            <button class="btn-icon">🗑️</button>
                        </form>
                        <% } %>
                    </td>
                </tr>
                <% }) %>
                </tbody>
            </table>
            <% } %>
        </div>
    </div>

    <!-- ── Member Sidebar ───────────────────────────────── -->
    <aside class="member-sidebar">
        <h4 class="members-title">👥 Mitglieder (<%= team.members.length %>)</h4>
        <ul class="member-list">
            <% team.members.forEach(member => { %>
            <li class="member-item">
                <span class="member-avatar"><%= member.username.charAt(0).toUpperCase() %></span>
                <span class="member-name">
                    <%= member.username %>
                    <% if (team.founder._id.toString() === member._id.toString()) { %>
                        <span class="badge badge-founder">Gründer</span>
                    <% } else if (team.admins.some(a => a._id.toString() === member._id.toString())) { %>
                        <span class="badge badge-admin">Admin</span>
                    <% } %>
                </span>
            </li>
            <% }) %>
        </ul>
    </aside>
</div>

<script>
function switchTab(name) {
    document.querySelectorAll('.tab-content').forEach(el => el.classList.remove('active'));
    document.querySelectorAll('.tab-btn').forEach(el => el.classList.remove('active'));
    document.getElementById('tab-' + name).classList.add('active');
    document.querySelector('[onclick="switchTab(\'' + name + '\')"]').classList.add('active');
    // update URL without reload
    const url = new URL(window.location);
    url.searchParams.set('tab', name);
    window.history.replaceState({}, '', url);
}
// Scroll chat to bottom on load
const feed = document.getElementById('chatFeed');
if (feed) feed.scrollTop = feed.scrollHeight;
</script>
</body>
</html>

