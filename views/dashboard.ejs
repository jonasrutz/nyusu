<!DOCTYPE html>
<html lang="de">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Dashboard | nyusu</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Poppins:wght@600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
    <link rel="stylesheet" href="/css/style.css">
    <% if (user && user.accentColor) { %>
    <style>
        :root {
            --accent: <%= user.accentColor %>;
            --accent-hover: <%= user.accentColor %>cc;
            --accent-glow: <%= user.accentColor %>4d;
        }
        .user-avatar, .team-avatar {
            background: linear-gradient(135deg, <%= user.accentColor %> 0%, <%= user.accentColor %>99 100%) !important;
            box-shadow: 0 4px 20px <%= user.accentColor %>66 !important;
        }
    </style>
    <% } %>
</head>
<body>
<%- include('./layout/sidebar') %>
<div class="main-content">
    <div class="page-header">
        <h2><i class="fas fa-compass"></i> Teams entdecken</h2>
    </div>

    <!-- Search -->
    <form action="/teams" method="GET" class="search-form">
        <input type="text" name="q" value="<%= query %>" placeholder="Team suchen…" class="search-input">
        <button type="submit" class="btn btn-secondary"><i class="fas fa-search"></i> Suchen</button>
        <% if (query) { %>
            <a href="/teams" class="btn btn-ghost">Zurücksetzen</a>
        <% } %>
    </form>

    <% if (query) { %>
        <p class="search-info">
            <% if (teams.length === 0) { %>
                Keine Teams für „<strong><%= query %></strong>" gefunden.
            <% } else { %>
                <%= teams.length %> Team(s) für „<strong><%= query %></strong>" gefunden.
            <% } %>
        </p>
    <% } %>

    <!-- Team Grid -->
    <div class="team-grid">
        <% teams.forEach(team => { %>
        <div class="team-card">
            <div class="team-card-header">
                <span class="team-avatar"><%= team.name.charAt(0).toUpperCase() %></span>
                <div>
                    <h3 class="team-name"><%= team.name %></h3>
                    <% if (team.game) { %><span class="team-game"><i class="fas fa-gamepad"></i> <%= team.game %></span><% } %>
                </div>
            </div>
            <p class="team-desc"><%= team.description || 'Keine Beschreibung.' %></p>
            <div class="team-card-footer">
                <span class="team-meta"><i class="fas fa-users"></i> <%= team.members.length %> Mitglied(er)</span>
                <a href="/teams/<%= team._id %>" class="btn btn-primary btn-sm">Öffnen</a>
            </div>
        </div>
        <% }) %>
    </div>

    <% if (teams.length === 0 && !query) { %>
    <div class="empty-state">
        <span class="empty-icon"><i class="fas fa-gamepad"></i></span>
        <p>Noch keine Teams vorhanden.</p>
        <a href="/teams/new" class="btn btn-primary">Erstes Team erstellen</a>
    </div>
    <% } %>
</div>
<script>
// Mobile Sidebar Toggle
(function() {
    const toggle = document.getElementById('mobileMenuToggle');
    const sidebar = document.getElementById('sidebar');
    const overlay = document.getElementById('sidebarOverlay');
    
    if (toggle && sidebar && overlay) {
        toggle.addEventListener('click', () => {
            sidebar.classList.toggle('open');
            overlay.classList.toggle('active');
            toggle.innerHTML = sidebar.classList.contains('open') 
                ? '<i class="fas fa-times"></i>' 
                : '<i class="fas fa-bars"></i>';
        });
        
        overlay.addEventListener('click', () => {
            sidebar.classList.remove('open');
            overlay.classList.remove('active');
            toggle.innerHTML = '<i class="fas fa-bars"></i>';
        });
    }
})();
</script>
</body>
</html>

